{
  "expo": {
    "name": "UHUB",
    "slug": "buhub-rn",
    "scheme": "buhub",
    "version": "0.1.7",
    "orientation": "portrait",
    "icon": "./assets/ios-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6750A4"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "10",
      "bundleIdentifier": "com.buhub.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSCameraUsageDescription": "UHUB needs camera access to take photos for posts, avatars, and messages.",
        "NSPhotoLibraryUsageDescription": "UHUB needs photo library access to select images for posts, avatars, and messages.",
        "NSMicrophoneUsageDescription": "UHUB needs microphone access to record voice messages.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/android-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon.png",
        "backgroundColor": "#6750A4"
      },
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.buhub.app",
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-localization",
        {
          "locales": {
            "en": "./assets/locales/en.json",
            "zh-Hant": "./assets/locales/zh-Hant.json",
            "zh-Hans": "./assets/locales/zh-Hans.json"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "UHUB needs camera access to scan QR codes and take photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "UHUB needs photo library access to save QR code images.",
          "savePhotosPermission": "UHUB needs permission to save QR code images to your photo library."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "UHUB needs microphone access for voice-to-text.",
          "speechRecognitionPermission": "UHUB needs speech recognition access to convert voice to text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://www.uhub.help/api",
      "hcaptchaSiteKey": "7a9ce63a-8a04-4cee-b196-ee9874482480",
      "termsUrl": "https://www.uhub.help/terms",
      "privacyUrl": "https://www.uhub.help/privacy",
      "eas": {
        "projectId": "86d0a94b-7e4f-4634-bae4-8ef0fc7c6b75"
      }
    }
  }
}
