{
  "expo": {
    "name": "ULink",
    "slug": "ulink-rn",
    "scheme": "ulink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ios-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "developmentClient": {
      "silentLaunch": true
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "14",
      "bundleIdentifier": "com.ulinks.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSCameraUsageDescription": "ULink needs camera access to take photos for posts, avatars, and messages.",
        "NSPhotoLibraryUsageDescription": "ULink needs photo library access to select images for posts, avatars, and messages.",
        "NSMicrophoneUsageDescription": "ULink needs microphone access for voice-to-text.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "ULink needs speech recognition access to convert voice to text."
      }
    },
    "android": {
      "icon": "./assets/android-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon.png",
        "backgroundColor": "#000000"
      },
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ulinks.app",
      "usesCleartextTraffic": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-localization",
        {
          "locales": {
            "en": "./assets/locales/en.json",
            "zh-Hant": "./assets/locales/zh-Hant.json",
            "zh-Hans": "./assets/locales/zh-Hans.json"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ULink needs camera access to scan QR codes and take photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ULink needs photo library access to save QR code images.",
          "savePhotosPermission": "ULink needs permission to save QR code images to your photo library."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "ULink needs microphone access for voice-to-text.",
          "speechRecognitionPermission": "ULink needs speech recognition access to convert voice to text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://www.uhub.help/api",
      "hcaptchaSiteKey": "7a9ce63a-8a04-4cee-b196-ee9874482480",
      "termsUrl": "https://www.uhub.help/terms",
      "privacyUrl": "https://www.uhub.help/privacy",
      "eas": {
        "projectId": "b995e2cb-f484-4127-aac9-f11a4841f10b"
      }
    },
    "owner": "davidzhangtest"
  }
}
