# API base URL (required - set in .env)
# Local dev: EXPO_PUBLIC_API_URL or EXPO_PUBLIC_DEV_API_URL
#   Android emulator: http://10.0.2.2:3000/api
#   iOS simulator: http://localhost:3000/api
# Production: https://your-domain.com/api
EXPO_PUBLIC_API_URL=

# Dev override (optional, used in __DEV__ when EXPO_PUBLIC_API_URL not set)
# iOS: http://localhost:3000/api  Android emulator: http://10.0.2.2:3000/api
EXPO_PUBLIC_DEV_API_URL=http://localhost:3000/api

# App base URL (optional, derived from EXPO_PUBLIC_API_URL if not set)
# EXPO_PUBLIC_APP_URL=https://your-domain.com

# Mock mode (optional, for testing without backend)
# EXPO_PUBLIC_USE_MOCK=true
# EXPO_PUBLIC_MOCK_BASE_URL= (derived from APP/API URL when not set)

# hCaptcha site key (get at https://dashboard.hcaptcha.com/)
EXPO_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# Legal (App Store compliance - required for HK/JP/US/EU)
EXPO_PUBLIC_TERMS_URL=https://www.uhub.help/terms
EXPO_PUBLIC_PRIVACY_URL=https://www.uhub.help/privacy
