{
  "expo": {
    "name": "UHUB",
    "slug": "buhub-rn",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6750A4"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "com.buhub.app",
      "infoPlist": {
        "NSAppTransportSecurity": { "NSAllowsArbitraryLoads": false },
        "NSCameraUsageDescription": "UHUB needs camera access to take photos for posts, avatars, and messages.",
        "NSPhotoLibraryUsageDescription": "UHUB needs photo library access to select images for posts, avatars, and messages.",
        "NSMicrophoneUsageDescription": "UHUB needs microphone access to record voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6750A4"
      },
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.buhub.app",
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-font"],
    "extra": {
      "hcaptchaSiteKey": "7a9ce63a-8a04-4cee-b196-ee9874482480"
    }
  }
}
